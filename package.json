    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.8.16",
    "typescript": "5.9.2",
    "vitest": "^4.1.0"
